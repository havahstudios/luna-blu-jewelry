# ── Sanity ────────────────────────────────────────────────────────────
# Get these from https://sanity.io → your project → Settings → API
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# ── Stripe ────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...        # use sk_test_... for testing
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── Site URL (used for Stripe redirect) ──────────────────────────────
# In production set this to your real domain, e.g. https://lunablujewelry.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
